# ============================================
# DevMetrics - Environment Variables Template
# ============================================
# Copy this file to .env and fill in the values

# PostgreSQL
POSTGRES_USER=devmetrics
POSTGRES_PASSWORD=devmetrics123
POSTGRES_DB=devmetrics

# Security
SECRET_KEY=09d25e094faa6ca2556c818166b7a9563b93f7099f6f0f4caa6cf63b88e8d3e7

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Slack Integration (optional)
# Create app at https://api.slack.com/apps → OAuth & Permissions
SLACK_CLIENT_ID=your_slack_client_id_here
SLACK_CLIENT_SECRET=your_slack_client_secret_here

# Jira Integration (optional)
# Create app at https://developer.atlassian.com/console/myapps/
JIRA_CLIENT_ID=your_jira_client_id_here
JIRA_CLIENT_SECRET=your_jira_client_secret_here

# Redis password (production only)
REDIS_PASSWORD=

# SMTP (for email reports — optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Environment
ENVIRONMENT=development
DEBUG=true
